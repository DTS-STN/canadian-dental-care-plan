{
  "name": "canadian-dental-care-plan",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "postinstall": "patch-package --patch-dir other/patches",
    "build": "npm run build:application && npm run build:server",
    "build:application": "react-router build",
    "build:server": "vite build --config ./vite.server.config.ts",
    "dev": "nodemon --config nodemon.json",
    "start": "cross-env NODE_ENV=production node --import ./build/server/opentelemetry.server.js ./build/server/express.server.js",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "run-s --continue-on-error -l format:check typecheck lint:eslint",
    "lint:fix": "run-s --continue-on-error -l format:fix lint:eslint:fix",
    "lint:eslint": "eslint --cache --cache-location ./node_modules/.cache/eslint ./",
    "lint:eslint:fix": "eslint --fix --cache --cache-location ./node_modules/.cache/eslint ./",
    "lint:eslint:summary": "eslint --format summary .",
    "typecheck": "react-router typegen && tsc",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui --coverage.enabled=true"
  },
  "dependencies": {
    "@date-fns/utc": "^2.1.1",
    "@dts-stn/health-checks": "^2.0.0",
    "@dts-stn/invariant": "^1.0.0",
