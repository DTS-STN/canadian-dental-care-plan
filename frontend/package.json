    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "react-idle-timer": "^5.7.3",
    "react-number-format": "^5.4.5",
    "react-phone-number-input": "^3.4.16",
    "react-router": "^7.14.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "source-map-support": "^0.5.21",
    "tailwind-merge": "^3.5.0",
    "triple-beam": "^1.4.1",
