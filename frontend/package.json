    "@types/compression": "^1.8.1",
    "@types/content-disposition": "^0.5.9",
    "@types/express-session": "^1.18.2",
    "@types/jsdom": "^28.0.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.2",
