    "content-disposition": "^1.1.0",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.5.12",
    "file-type": "^22.0.1",
    "filesize": "^11.0.15",
    "i18next": "^26.0.4",
    "i18next-http-backend": "^3.0.4",
    "inversify": "^8.1.0",
    "isbot": "^5.1.38",
